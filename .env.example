PORT=3000

# MySQL database
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Dev only: forces all requests to one salon (remove in production)
# SALON_SLUG=next-level-salon

# Super admin panel — set a strong password
SUPER_ADMIN_PASSWORD=change-me

# Meta WhatsApp Cloud API
# Set in Railway env vars — per-salon credentials stored in DB via admin panel
META_WEBHOOK_VERIFY_TOKEN=your-random-string-here

# Twilio SMS (optional — replaced by WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+49xxxxxxxxxx
